# PSX Alert System — Environment Variables
# Copy this to .env for local development
# On Railway: add these in the Variables tab (never commit .env to GitHub)

# Required: Your Resend API key
RESEND_API_KEY=your_resend_api_key_here

# Optional: Override recipient email (defaults to bilalasif3458@gmail.com)
# ALERT_EMAIL=bilalasif3458@gmail.com

# Optional: Override sender (defaults to Resend test domain)
# FROM_EMAIL=PSX Alerts <alerts@yourdomain.com>
